  "definitions": {
    "phone": {
      "type": "string",
      "format": "tel"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "address": {
      "type": "object",
      "view": {
        "class": "row",
        "info": "Ingresa tu código postal y selecciona una de las opciones"
      },
      "properties": {
        "zipcode": {
          "title": "Código Postal",
          "type": "string",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "state": {
          "title": "Estado",
          "type": "string",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "city": {
          "title": "Municipio, Delegación o Ciudad",
          "type": "string",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "neighborhood": {
          "title": "Colonia",
          "type": "string",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "street": {
          "title": "Calle",
          "type": "string",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "numberExt": {
          "title": "No. exterior",
          "type": "string",
          "view": {
            "class": "col col-6 col-sm-3 col-md-2 pr-1"
          }
        },
        "numberInt": {
          "title": "No. interior",
          "type": "string",
          "view": {
            "class": "col col-6 col-sm-3 col-md-2 pl-1"
          }
        }
      }
    }
  }
