{
  "title": "Registro de Agentes",
  "type": "object",
  "properties": {
    "documents": {
      "title": "Documentos",
      "description": "Adjunta los siguientes documentos:",
      "type": "object",
      "view": {
        "class": "row"
      },
      "properties": {
        "agentId": {
          "title": "Cédula de agente (frente)",
          "description": "Adjuntar...",
          "type": "file",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "agentIdBack": {
          "title": "Cédula de agente (vuelta)",
          "description": "Adjuntar...",
          "type": "file",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4"
          }
        },
        "account": {
          "title": "Primera hoja de tu Estado de Cuenta",
          "description": "Adjuntar...",
          "type": "file",
          "required": true,
          "view": {
            "class": "col col-12 col-sm-6 col-md-4 mb-4",
            "info": "Se requiere para ver tu número de cuenta y cuenta CLABE (recuerda ocultar tus movimientos financieros)."
          }
        }
      }
    },
    "agreement": {
      "title": "Contrato",
      "description": "Llena los siguientes campos para completar tu contrato:",
      "type": "object",
      "properties": {
        "fullname": {
          "title": "Nombre completo",
          "type": "object",
          "view": {
            "class": "row"
          },
          "properties": {
            "name": {
              "title": "Nombre(s)",
              "type": "string",
              "required": true,
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            },
            "firstSurname": {
              "title": "Apellido Paterno",
              "type": "string",
              "required": true,
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            },
            "secondSurname": {
              "title": "Apellido Materno",
              "type": "string",
              "required": true,
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            }
          }
        },
        "contact": {
          "title": "Contacto",
          "type": "object",
          "view": {
            "class": "row"
          },
          "properties": {
            "phoneOffice": {
              "title": "Teléfono de Oficina",
              "$ref": "#/definitions/phone",
              "required": true,
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            },
            "phoneMobile": {
              "title": "Teléfono Celular",
              "$ref": "#/definitions/phone",
              "required": true,
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            },
            "phonePersonal": {
              "title": "Teléfono Partcular",
              "$ref": "#/definitions/phone",
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            },
            "email": {
              "title": "Correo electrónico",
              "$ref": "#/definitions/email",
              "required": true,
              "view": {
                "class": "col col-12 col-sm-6 col-md-4 mb-4"
              }
            }
          }
        },
        "address": {
          "title": "Dirección",
          "$ref": "#/definitions/address"
        },
