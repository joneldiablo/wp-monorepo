        "operations": {
          "title": " ",
          "type": "object",
          "view": {
            "class": "row"
          },
          "properties": {
            "list": {
              "title": "Operaciones y Ramos autorizados para intermediar del agente",
              "type": "array",
              "format": "csv",
              "required": true,
              "enum": [
                "A - Riesgos Personales y Familiares de Seguros de Personas y Daños",
                "A1 - Riesgos Personales y Familiares de Seguros de Personas",
                "A2 - Riesgos Personales y Familiares de Seguros de Daños",
                "B - Riesgos Empresariales de Seguros de Personas y Daños",
                "B1 - Riesgos Empresariales de Seguros de Personas",
                "B2 - Riesgos Empresariales de Seguros de Daños",
                "C - Riesgos Especiales",
                "D - Agrícola y de Animales",
                "E - Seguro de Crédito",
                "G - Especiales",
                "H - Seguro de pensiones derivadas de las leyes de seguridad soc."
              ],
              "view": {
                "class": "col col-12",
                "label": true,
                "info": "Oprime la tecla \"ctrl\" o \"cmd\" y da click en las opciones para marcar varias"
              }
            }
          }
