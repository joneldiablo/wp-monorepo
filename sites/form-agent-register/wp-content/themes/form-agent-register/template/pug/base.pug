  .modal.fade#confirmModal(tabindex='-1' role='dialog' aria-labelledby='confirmModalLabel' aria-hidden='true')
    .modal-dialog(role='document')
      .modal-content
        button.close.align-self-end.m-2.px-2.border.rounded-circle(type='button' data-dismiss='modal' aria-label='Close')
          span(aria-hidden='true') ×
        .modal-body
          h5.text-center.modal-title.mb-4#confirmModalLabel ¿Quieres verificar que tu información esté correcta?
          .row.justify-content-around
            .col.col-12.col-sm-6.col-md-5.col-lg-4
              button.btn.btn-block(type='button' data-dismiss='modal') VERIFICAR INFORMACIÓN
            .col.col-12.col-sm-6.col-md-5.col-lg-4
              button#submitConfirm.btn.btn-block(type='button') CONFIRMAR ENVÍO
