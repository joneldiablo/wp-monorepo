include ./form-field
include ./schema-recursive
include ./modal

.container.py-4
  form.form(enctype="multipart/form-data" method='POST' action="./save-form" id="formComplaint")
    .row
      +schema-recursive(site.data.schema)
    .row
      .col.col-12.mb-4
        p.text-center
          a#moreOpenModal.text-info.font-weight-bold(href="#" data-toggle="modal" data-target="#moreForm_modal") ¿Quieres dejarnos más información de tu queja? Click aquí
    #moveToModal
      .row.mb-4
        .col.col-12
          .custom-control.custom-checkbox
            input#terms.custom-control-input(type="checkbox" required)
            label.custom-control-label(for="terms")
              | Acepto 
              a.text-reset(href="./terminos-y-condiciones" style="text-decoration:underline" target="_blank") términos y condiciones
              | .
      .row.justify-content-center
        .col.col-12.col-sm-8.col-md-6.col-lg-4
          button.btn.btn-outline-light.btn-block(type="submit") ENVIAR
  +modal({id:'response', bodyClass:"text-body"})